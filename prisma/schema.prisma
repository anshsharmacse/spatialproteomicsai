// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AnalysisSession {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("pending") // pending, processing, completed, failed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  proteinSpots    ProteinSpot[]
  predictions     Prediction[]
  trainingMetrics TrainingMetric[]
}

model ProteinSpot {
  id           String  @id @default(cuid())
  sessionId    String
  x            Float
  y            Float
  protein      String
  expression   Float
  cellType     String?
  createdAt    DateTime @default(now())
  
  session      AnalysisSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId])
}

model Prediction {
  id              String  @id @default(cuid())
  sessionId       String
  spotId          String
  prediction      String
  confidence      Float
  nuclear         Float   @default(0)
  cytoplasmic     Float   @default(0)
  membrane        Float   @default(0)
  extracellular   Float   @default(0)
  mitochondrial   Float   @default(0)
  createdAt       DateTime @default(now())
  
  session         AnalysisSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId])
}

model TrainingMetric {
  id        String   @id @default(cuid())
  sessionId String
  epoch     Int
  loss      Float
  accuracy  Float
  createdAt DateTime @default(now())
  
  session   AnalysisSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId])
}
